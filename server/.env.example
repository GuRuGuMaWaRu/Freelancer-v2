# Copy to the repo root as `.env.server` before running the server locally:
#   cp server/.env.example .env.server
#
# Required for local development and server tests.

# MongoDB connection strings
DB_MAIN=mongodb://127.0.0.1:27017/freelancer
DB_DEVELOPMENT=mongodb://127.0.0.1:27017/freelancer_dev
DB_TEST=mongodb://127.0.0.1:27017/freelancer_test

# JWT (use a long random string in real environments)
ACCESS_TOKEN_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Express listen port — must match VITE_API_PORT in client/.env.development (default 6040).
# Port 6000 is in the Windows Hyper-V excluded range 5940-6039 and will fail with EACCES.
PORT=6040

# Pino log level: silent | fatal | error | warn | info | debug | trace
# Defaults: info (dev/prod), error (test). Successful HTTP requests log at info
# (compact: method, url, status, responseTime). Use warn to hide 2xx request lines.
# LOG_LEVEL=warn
