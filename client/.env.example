# Optional client env vars for local development.
# Copy to `.env.development.local` to override Vite defaults without editing tracked files:
#   cp client/.env.example client/.env.development.local

# API proxy target — must match PORT in repo-root `.env.server` (default 4000)
# VITE_API_PORT=4000

# Vite dev server port (default 3000)
# VITE_PORT=3000
