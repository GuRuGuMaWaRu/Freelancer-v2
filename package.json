{
  "name": "freelancer",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.16.0"
  },
  "scripts": {
    "prod": "concurrently \"npm run server:prod\" \"npm run client\"",
    "start": "npm start --prefix server",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "client": "npm start --prefix client",
    "client:install": "npm install --prefix client",
    "server:install": "npm install --prefix server",
    "client:test": "npm run test --prefix client -- --coverage --run",
    "server:prod": "cross-env NODE_ENV=development USE_PROD_DB=true tsx watch server/app.ts",
    "server:dev": "cross-env NODE_ENV=development tsx watch server/app.ts",
    "server:test": "cross-env NODE_ENV=test mocha --require tsx/cjs --file server/test/test-helpers.ts \"server/test/**/*.test.ts\"",
    "lint": "eslint --ignore-path .gitignore --ext .js,.ts,.tsx .",
    "check-types": "npm-run-all --parallel check-types:client check-types:server",
    "check-types:client": "tsc --noEmit",
    "check-types:server": "tsc --noEmit -p server/tsconfig.json",
    "prettier": "prettier --ignore-path .gitignore --write \"**/*.+(js|json|ts|tsx)\"",
    "format": "npm run prettier -- --write",
    "check-format": "npm run prettier -- --list-different",
    "validate": "npm-run-all --parallel check-types check-format lint"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^5.39.0",
    "@typescript-eslint/parser": "^5.39.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.32.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-config-prettier": "^6.9.0",
    "eslint-plugin-import": "^2.20.0",
    "eslint-plugin-jest": "^27.1.1",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-node": "^11.0.0",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-react": "^7.18.0",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "mocha": "^10.2.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^1.19.1",
    "supertest": "^4.0.2",
    "tsx": "^4.22.5"
  }
}
